# Server Settings
PORT=3000
NODE_ENV=development

# Database Settings (SQLite)
DATABASE_URL="file:./dev.db"

# Authentication Settings
JWT_SECRET="super-secret-key-change-me-in-production-123456"
JWT_EXPIRES_IN="24h"

# Stripe Payment Settings (Optional - if missing, API uses mock sandbox payment mode)
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Email Notifications Settings (Optional - if missing, API uses Ethereal testing SMTP)
EMAIL_HOST=""
EMAIL_PORT=587
EMAIL_USER=""
EMAIL_PASS=""
EMAIL_FROM="E-Commerce Store <noreply@ecommerce.com>"
